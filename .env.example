# ==========================================
# SOL EMA Monitor v2 — Environment Config
# ==========================================

# ── Birdeye API ───────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius RPC (Developer tier) ───────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_API_KEY=your_helius_api_key_here

# ── Jupiter API (Pro I) ───────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ── Trading Wallet ────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Trade sizing ──────────────────────────
TRADE_SIZE_SOL=0.2

# ── Slippage & MEV protection ─────────────
SLIPPAGE_BPS=300
USE_JITO=true
JITO_TIP_LAMPORTS=1000000
PRIORITY_FEE_MICROLAMPORTS=100000

# ── Take-profit levels（分批止盈）──────────
# TP_ENABLED=false → 暂停分批止盈，EMA死叉时一次性全仓退出
# TP_ENABLED=true  → 启用分批止盈
TP_ENABLED=false
TP1_PCT=100   # +100% gain → sell 33%
TP1_SELL=33
TP2_PCT=200   # +200% gain → sell 33% of remainder
TP2_SELL=33
TP3_PCT=400   # +400% gain → sell 50% of remainder
TP3_SELL=50

# ── Hard stop-loss ────────────────────────
# 跌超此百分比立即全仓清出
STOP_LOSS_PCT=25

# ── Trailing stop after breakeven ─────────
# 峰值回撤超过 TRAIL_PCT 触发移动止损
TRAIL_PCT=30

# ── 移动止损激活门槛 ──────────────────────
# 峰值涨幅超过此值后才激活移动止损
TRAIL_ACTIVATE_PCT=50

# ── Server ────────────────────────────────
PORT=3001

# ── Token monitoring window ───────────────
TOKEN_MAX_AGE_MINUTES=120

# ── FDV gate ──────────────────────────────
FDV_MIN_USD=15000
FDV_MAX_USD=60000
LP_MIN_USD=5000

# ── EMA parameters ────────────────────────
EMA_FAST=9
EMA_SLOW=20
EMA_CONFIRM_BARS=2

# ── Timing ────────────────────────────────
PRICE_POLL_SEC=1
KLINE_INTERVAL_SEC=300
