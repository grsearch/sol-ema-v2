# ==========================================
# SOL EMA Monitor v2 — Environment Config
# ==========================================

# ── Birdeye API ───────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius RPC (Developer tier) ───────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_API_KEY=your_helius_api_key_here

# ── Jupiter API (Pro I) ───────────────────
# Pro I endpoint — no /price/v2 rate limits
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ── Trading Wallet ────────────────────────
# Base58 private key of the wallet used for trading
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Trade sizing ──────────────────────────
# SOL amount per trade (each BUY uses this fixed amount)
TRADE_SIZE_SOL=0.5

# ── Slippage & MEV protection ─────────────
# Slippage in basis points (100 = 1%)
SLIPPAGE_BPS=300
# Use Jito MEV-protect bundles (true/false)
USE_JITO=true
# Jito tip in lamports (0.001 SOL = 1_000_000)
JITO_TIP_LAMPORTS=1000000
# Priority fee in microlamports per CU
PRIORITY_FEE_MICROLAMPORTS=100000

# ── Take-profit levels (分批止盈) ──────────
# Sell pct of remaining position at each level (0–100)
TP1_PCT=100   # +100% gain → sell 33%
TP1_SELL=33
TP2_PCT=200   # +200% gain → sell 33% of remainder
TP2_SELL=33
TP3_PCT=400   # +400% gain → sell 50% of remainder
TP3_SELL=50
# TP4: remainder rides until EMA death cross

# ── Hard stop-loss ────────────────────────
# Exit 100% if price drops this % below entry

STOP_LOSS_PCT=30

# ── Trailing stop after breakeven ─────────
# 移动止损：峰值涨幅>=TRAIL_ACTIVATE_PCT 后，trailStop = peakPrice × (1 - TRAIL_PCT/100)
TRAIL_PCT=30

# ── 移动止损激活门槛 ──────────────────────
# 峰值涨幅超过此值后激活移动止损（默认50%）
TRAIL_ACTIVATE_PCT=50

# ── Server ────────────────────────────────
PORT=3001

# ── Token monitoring window ───────────────
TOKEN_MAX_AGE_MINUTES=240

# ── FDV gate ──────────────────────────────
FDV_MIN_USD=20000
FDV_MAX_USD=50000  # FDV上限，超过此值拒绝买入

# ── EMA parameters ────────────────────────
EMA_FAST=9
EMA_SLOW=20
EMA_CONFIRM_BARS=2

# ── Timing ────────────────────────────────
PRICE_POLL_SEC=1
KLINE_INTERVAL_SEC=300
